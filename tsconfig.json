{
  "compilerOptions": {
    "moduleResolution": "node",
    "target": "ES2017",
    "module":"es2015",
    "lib": ["ES2017", "DOM", "DOM.Iterable"],
    "strict": true,
    "sourceMap": true,
    "declaration": true,
    "allowSyntheticDefaultImports": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "declarationDir": "dist",
    "outDir": "dist/lib",
    "types": [],
    "typeRoots": [
      "node_modules/@types"
    ]
  },
  "include": [
    "src/**/*"
  ]
}
