{
  "name": "@lightgallery/vue",
  "version": "3.0.0-alpha.1",
  "private": false,
  "description": "Native Vue 3 lightGallery over @lightgallery/headless",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./plugins/thumbnail": {
      "import": {
        "types": "./dist/plugins/thumbnail/index.d.ts",
        "default": "./dist/plugins/thumbnail/index.js"
      },
      "require": {
        "types": "./dist/plugins/thumbnail/index.d.cts",
        "default": "./dist/plugins/thumbnail/index.cjs"
      }
    },
    "./plugins/zoom": {
      "import": {
        "types": "./dist/plugins/zoom/index.d.ts",
        "default": "./dist/plugins/zoom/index.js"
      },
      "require": {
        "types": "./dist/plugins/zoom/index.d.cts",
        "default": "./dist/plugins/zoom/index.cjs"
      }
    },
    "./plugins/video": {
      "import": {
        "types": "./dist/plugins/video/index.d.ts",
        "default": "./dist/plugins/video/index.js"
      },
      "require": {
        "types": "./dist/plugins/video/index.d.cts",
        "default": "./dist/plugins/video/index.cjs"
      }
    },
    "./plugins/autoplay": {
      "import": {
        "types": "./dist/plugins/autoplay/index.d.ts",
        "default": "./dist/plugins/autoplay/index.js"
      },
      "require": {
        "types": "./dist/plugins/autoplay/index.d.cts",
        "default": "./dist/plugins/autoplay/index.cjs"
      }
    },
    "./plugins/fullscreen": {
      "import": {
        "types": "./dist/plugins/fullscreen/index.d.ts",
        "default": "./dist/plugins/fullscreen/index.js"
      },
      "require": {
        "types": "./dist/plugins/fullscreen/index.d.cts",
        "default": "./dist/plugins/fullscreen/index.cjs"
      }
    },
    "./plugins/hash": {
      "import": {
        "types": "./dist/plugins/hash/index.d.ts",
        "default": "./dist/plugins/hash/index.js"
      },
      "require": {
        "types": "./dist/plugins/hash/index.d.cts",
        "default": "./dist/plugins/hash/index.cjs"
      }
    },
    "./plugins/pager": {
      "import": {
        "types": "./dist/plugins/pager/index.d.ts",
