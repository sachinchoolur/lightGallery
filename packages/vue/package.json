{
  "name": "@lightgallery/vue",
  "version": "3.0.0-alpha.0",
  "private": true,
  "description": "Native Vue 3 lightGallery over @lightgallery/headless",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && vue-tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json",
    "lint": "eslint 'src/**/*.{ts,vue}' --quiet"
  },
  "dependencies": {
    "@lightgallery/headless": "workspace:*"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.17.0",
    "eslint-plugin-vue": "^10.0.0",
    "jsdom": "^26.0.0",
    "typescript": "~5.9.0",
    "typescript-eslint": "^8.19.0",
    "vite": "^7.0.0",
    "vitest": "^4.1.0",
    "vue": "^3.5.0",
    "vue-eslint-parser": "^10.3.0",
    "vue-tsc": "^3.0.0"
  }
}
