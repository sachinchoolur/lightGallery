{
  "name": "@lightgallery/vue",
  "version": "3.0.0-alpha.0",
  "private": true,
  "description": "Native Vue 3 lightGallery over @lightgallery/headless",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./plugins/thumbnail": {
      "types": "./dist/plugins/thumbnail/index.d.ts",
      "import": "./dist/plugins/thumbnail/index.js",
      "require": "./dist/plugins/thumbnail/index.cjs"
    },
    "./plugins/zoom": {
      "types": "./dist/plugins/zoom/index.d.ts",
      "import": "./dist/plugins/zoom/index.js",
      "require": "./dist/plugins/zoom/index.cjs"
    },
    "./plugins/video": {
      "types": "./dist/plugins/video/index.d.ts",
      "import": "./dist/plugins/video/index.js",
      "require": "./dist/plugins/video/index.cjs"
    },
    "./plugins/autoplay": {
      "types": "./dist/plugins/autoplay/index.d.ts",
      "import": "./dist/plugins/autoplay/index.js",
      "require": "./dist/plugins/autoplay/index.cjs"
    },
    "./plugins/fullscreen": {
      "types": "./dist/plugins/fullscreen/index.d.ts",
      "import": "./dist/plugins/fullscreen/index.js",
      "require": "./dist/plugins/fullscreen/index.cjs"
    },
    "./plugins/hash": {
      "types": "./dist/plugins/hash/index.d.ts",
      "import": "./dist/plugins/hash/index.js",
      "require": "./dist/plugins/hash/index.cjs"
    },
    "./plugins/pager": {
      "types": "./dist/plugins/pager/index.d.ts",
      "import": "./dist/plugins/pager/index.js",
      "require": "./dist/plugins/pager/index.cjs"
    },
    "./plugins/share": {
      "types": "./dist/plugins/share/index.d.ts",
      "import": "./dist/plugins/share/index.js",
      "require": "./dist/plugins/share/index.cjs"
    },
    "./plugins/rotate": {
      "types": "./dist/plugins/rotate/index.d.ts",
      "import": "./dist/plugins/rotate/index.js",
      "require": "./dist/plugins/rotate/index.cjs"
    },
    "./plugins/comment": {
      "types": "./dist/plugins/comment/index.d.ts",
      "import": "./dist/plugins/comment/index.js",
      "require": "./dist/plugins/comment/index.cjs"
    },
    "./plugins/mediumZoom": {
      "types": "./dist/plugins/mediumZoom/index.d.ts",
      "import": "./dist/plugins/mediumZoom/index.js",
      "require": "./dist/plugins/mediumZoom/index.cjs"
    },
    "./plugins/relativeCaption": {
      "types": "./dist/plugins/relativeCaption/index.d.ts",
      "import": "./dist/plugins/relativeCaption/index.js",
      "require": "./dist/plugins/relativeCaption/index.cjs"
    },
    "./plugins/vimeoThumbnail": {
      "types": "./dist/plugins/vimeoThumbnail/index.d.ts",
      "import": "./dist/plugins/vimeoThumbnail/index.js",
      "require": "./dist/plugins/vimeoThumbnail/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && vue-tsc -p tsconfig.build.json && node ../../scripts/copy-dts-to-cts.mjs dist",
    "dev": "vite --config dev/vite.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json",
    "lint": "eslint 'src/**/*.{ts,vue}' --quiet"
  },
  "dependencies": {
    "@lightgallery/headless": "workspace:*"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.17.0",
    "eslint-plugin-vue": "^10.0.0",
    "jsdom": "^26.0.0",
    "typescript": "~5.9.0",
    "typescript-eslint": "^8.19.0",
    "vite": "^7.0.0",
    "vitest": "^4.1.0",
    "vue": "^3.5.0",
    "vue-eslint-parser": "^10.3.0",
    "vue-tsc": "^3.0.0"
  }
}
