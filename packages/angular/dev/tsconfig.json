{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "module": "ES2022",
    "moduleResolution": "bundler",
    "noEmit": false,
    "types": [],
    "baseUrl": ".",
    "paths": {
      "@lightgallery/angular": ["../src/public-api.ts"],
      "@lightgallery/angular/plugins/*": ["../plugins/*/index.ts"],
      "@lightgallery/headless": ["../../headless/src/index.ts"]
    }
  },
  "include": [
    "./**/*.ts",
    "../src/**/*.ts",
    "../plugins/**/*.ts",
    "../../headless/src/**/*.ts"
  ]
}
