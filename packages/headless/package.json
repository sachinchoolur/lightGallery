{
  "name": "@lightgallery/headless",
  "version": "3.0.0-alpha.1",
  "private": false,
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "publishConfig": {
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "import": {
          "types": "./dist/index.d.ts",
          "default": "./dist/index.js"
        },
        "require": {
          "types": "./dist/index.d.cts",
          "default": "./dist/index.cjs"
        }
      }
    },
    "access": "public",
    "tag": "alpha"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json && node ../../scripts/copy-dts-to-cts.mjs dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint src --quiet"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.19.0",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  },
  "license": "GPL-3.0-only",
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sachinchoolur/lightGallery.git",
    "directory": "packages/headless"
  },
  "homepage": "https://www.lightgalleryjs.com/",
  "bugs": {
    "url": "https://github.com/sachinchoolur/lightGallery/issues"
  },
  "keywords": [
    "lightgallery",
    "gallery",
    "lightbox",
    "headless",
    "state-machine",
    "framework-agnostic"
  ],
  "author": {
    "name": "Sachin Neravath"
  }
}
